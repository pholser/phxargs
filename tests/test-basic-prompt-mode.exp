#!/usr/bin/env expect -f

set script_dir [file dirname [file normalize [info script]]]
set build_dir [expr {[info exists env(PHX_BUILD_DIR)] ? $env(PHX_BUILD_DIR) : "$script_dir/../build"}]
set phxargs_bin "$build_dir/phxargs"

spawn $phxargs_bin -p echo "test"

send "arg1 arg2\r"
send \x04

set timeout 60
expect {
  "echo test arg1 arg2*" {
    send "y\r"
    expect "test"
    expect eof
  }
  timeout {
    puts "Timeout occurred"
    exit 1
  }
  eof {
    puts "EOF occurred unexpectedly"
    exit 1
  }
}

catch wait result
set exit_status [lindex $result 3]
exit $exit_status
